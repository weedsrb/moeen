# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini AI
GEMINI_API_KEY=
AI_PROVIDER=gemini
GEMINI_CONVERSATION_MODEL=gemini-2.5-flash
GEMINI_CLASSIFIER_MODEL=gemini-2.5-flash-lite

# Protected n8n -> Muin automation API. JSON supports overlap during rotation.
MUIN_AUTOMATION_HMAC_KEYS={"n8n-prod-1":"replace-with-at-least-32-random-bytes"}

# Merchant email verification and quota protection in the Muin application.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Muin <notifications@example.com>
AUTOMATION_EMAIL_DAILY_LIMIT=100

# WhatsApp Cloud API (retired from active surface — kept for re-enablement)
# Credentials are stored per-merchant in the database, not here.

# Instagram API with Instagram Login (primary channel)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=     # single app-level token you choose
INSTAGRAM_REDIRECT_URI=             # {NEXT_PUBLIC_APP_URL}/api/auth/instagram/callback

# Secret for the token-refresh cron route (Authorization: Bearer <value>)
CRON_SECRET=

# App URL (used for webhook verification + OAuth redirect)
NEXT_PUBLIC_APP_URL=
