# Copy to .env on the OCI host. Never commit the real file.
N8N_HOST=automation.example.com
N8N_STAGING_HOST=automation-staging.example.com
ACME_EMAIL=ops@example.com
GENERIC_TIMEZONE=Asia/Hebron

N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=replace-with-a-long-random-value
N8N_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes

N8N_STAGING_DB_NAME=n8n_staging
N8N_STAGING_DB_USER=n8n_staging
N8N_STAGING_DB_PASSWORD=replace-with-a-different-random-value
N8N_STAGING_ENCRYPTION_KEY=replace-with-a-different-random-key

N8N_EXECUTION_MAX_AGE_HOURS=168
AI_WORKER_CONCURRENCY=3
AI_WORKER_POLL_MS=1000
AI_WORKER_VISIBILITY_SECONDS=90

# age public recipient used by scripts/backup.sh to encrypt backups.
BACKUP_AGE_RECIPIENT=age1replace-with-your-off-host-recipient
BACKUP_RETENTION_DAYS=14
# Directory for the encrypted *.age backups (optional).
# scripts/backup.sh and scripts/restore.sh default to ./backups when unset.
# BACKUP_DIR=./backups
# age identity (private key) file, used ONLY by scripts/restore.sh to decrypt.
# Backups are recipient-encrypted, so restore requires the matching identity.
# In production the identity is kept OFF-server (on the operator's machine) and
# only the public BACKUP_AGE_RECIPIENT lives in server env. Set this to the
# identity path only when running a restore drill against a non-production
# target, e.g. BACKUP_AGE_IDENTITY=/path/to/backup-identity.txt
# BACKUP_AGE_IDENTITY=

# scripts/cutover-ai.sh reads SUPABASE_URL (or NEXT_PUBLIC_SUPABASE_URL),
# SUPABASE_SERVICE_ROLE_KEY, and AI_CUTOVER_CONFIRM=<queue|inline> at invocation
# time. These overlap with .env.worker values and must NOT be stored here; pass
# them inline on the command that runs the cutover.

# n8n workflow egress. Use the same HMAC key id/secret in the Muin app runtime.
MUIN_APP_BASE_URL=https://app.example.com
MUIN_AUTOMATION_HMAC_KEY_ID=n8n-prod-1
MUIN_AUTOMATION_HMAC_SECRET=replace-with-at-least-32-random-bytes
RESEND_API_KEY=re_replace-on-host-only
RESEND_FROM_EMAIL=Muin <notifications@example.com>

# Staging must use a different Muin deployment/key and a Resend test domain.
MUIN_STAGING_APP_BASE_URL=https://staging.example.com
MUIN_STAGING_AUTOMATION_HMAC_KEY_ID=n8n-staging-1
MUIN_STAGING_AUTOMATION_HMAC_SECRET=replace-with-a-different-random-value
RESEND_STAGING_API_KEY=re_replace-with-staging-key
RESEND_STAGING_FROM_EMAIL=Muin Staging <staging-notifications@example.com>
