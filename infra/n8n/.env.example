# Copy to .env on the OCI host. Never commit the real file.
N8N_HOST=automation.example.com
N8N_STAGING_HOST=automation-staging.example.com
ACME_EMAIL=ops@example.com
GENERIC_TIMEZONE=Asia/Hebron

N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=replace-with-a-long-random-value
N8N_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes

N8N_STAGING_DB_NAME=n8n_staging
N8N_STAGING_DB_USER=n8n_staging
N8N_STAGING_DB_PASSWORD=replace-with-a-different-random-value
N8N_STAGING_ENCRYPTION_KEY=replace-with-a-different-random-key

N8N_EXECUTION_MAX_AGE_HOURS=168
AI_WORKER_CONCURRENCY=3
AI_WORKER_POLL_MS=1000
AI_WORKER_VISIBILITY_SECONDS=90

# age public recipient used by scripts/backup.sh.
BACKUP_AGE_RECIPIENT=age1replace-with-your-off-host-recipient
BACKUP_RETENTION_DAYS=14

# n8n workflow egress. Use the same HMAC key id/secret in the Muin app runtime.
MUIN_APP_BASE_URL=https://app.example.com
MUIN_AUTOMATION_HMAC_KEY_ID=n8n-prod-1
MUIN_AUTOMATION_HMAC_SECRET=replace-with-at-least-32-random-bytes
RESEND_API_KEY=re_replace-on-host-only
RESEND_FROM_EMAIL=Muin <notifications@example.com>
